{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kstreet.local/schemas/kstreet_person_profile.v3.json",
  "title": "HTF / K Street Person Profile v3",
  "description": "Canonical source-of-truth profile schema for HTF / K Street people and shared characters across narrative, game, AI, relationship, and memory systems.",
  "type": "object",
  "required": [
    "schema_version",
    "schema_id",
    "profile_id",
    "created_at",
    "updated_at",
    "consent",
    "identity",
    "appearance",
    "asset_library",
    "personality",
    "motivation",
    "decision_making",
    "social_model",
    "relationship_graph",
    "knowledge_domains",
    "humor_and_voice",
    "conflict_and_stress",
    "signature_behaviors",
    "narrative_engine",
    "game_mechanics",
    "ai_generation",
    "project_usage",
    "source_notes",
    "governance",
    "profile_evolution",
    "generated_content",
    "extensions"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": "3.0.0" },
    "schema_id": { "const": "kstreet_person_profile.v3" },
    "profile_id": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "entity": { "$ref": "#/$defs/graph_entity" },
    "consent": { "$ref": "#/$defs/object" },
    "identity": { "$ref": "#/$defs/object" },
    "appearance": { "$ref": "#/$defs/object" },
    "asset_library": {
      "type": "object",
      "required": ["primary_reference_asset_id", "primary_portrait_asset_id", "primary_sprite_asset_id", "primary_model_asset_id", "assets", "asset_groups", "style_guides"],
      "properties": {
        "primary_reference_asset_id": { "type": "string" },
        "primary_portrait_asset_id": { "type": "string" },
        "primary_sprite_asset_id": { "type": "string" },
        "primary_model_asset_id": { "type": "string" },
        "assets": {
          "type": "array",
          "items": { "$ref": "#/$defs/asset" }
        },
        "asset_groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/asset_group" }
        },
        "style_guides": {
          "type": "array",
          "items": { "$ref": "#/$defs/style_guide" }
        }
      },
      "additionalProperties": true
    },
    "knowledge_graph": {
      "type": "object",
      "description": "HTF / K Street Knowledge Graph v4 foundation layer. Existing v3 person profiles become person entities without changing the v3 profile contract.",
      "required": ["graph_schema_version", "graph_id", "root_entity_id", "entities", "relationship_entities", "organizations", "locations", "events", "assets", "projects", "links", "timeline"],
      "properties": {
        "graph_schema_version": { "const": "4.0.0-foundation" },
        "graph_id": { "type": "string" },
        "root_entity_id": { "type": "string" },
        "entities": { "type": "array", "items": { "$ref": "#/$defs/graph_entity" } },
        "relationship_entities": { "type": "array", "items": { "$ref": "#/$defs/relationship_entity" } },
        "organizations": { "type": "array", "items": { "$ref": "#/$defs/organization_entity" } },
        "factions": { "type": "array", "items": { "$ref": "#/$defs/faction_entity" } },
        "locations": { "type": "array", "items": { "$ref": "#/$defs/location_entity" } },
        "events": { "type": "array", "items": { "$ref": "#/$defs/event_entity" } },
        "assets": { "type": "array", "items": { "$ref": "#/$defs/graph_entity" } },
        "story_objects": { "type": "array", "items": { "$ref": "#/$defs/story_object_entity" } },
        "projects": { "type": "array", "items": { "$ref": "#/$defs/project_entity" } },
        "concepts": { "type": "array", "items": { "$ref": "#/$defs/concept_entity" } },
        "links": { "type": "array", "items": { "$ref": "#/$defs/graph_link" } },
        "timeline": { "type": "array", "items": { "$ref": "#/$defs/timeline_entry" } },
        "generated": { "$ref": "#/$defs/object" }
      },
      "additionalProperties": true
    },
    "personality": { "$ref": "#/$defs/object" },
    "motivation": { "$ref": "#/$defs/object" },
    "decision_making": { "$ref": "#/$defs/object" },
    "social_model": { "$ref": "#/$defs/object" },
    "relationship_graph": {
      "type": "array",
      "items": { "$ref": "#/$defs/relationship" }
    },
    "knowledge_domains": {
      "type": "array",
      "items": { "$ref": "#/$defs/knowledge_domain" }
    },
    "humor_and_voice": { "$ref": "#/$defs/object" },
    "conflict_and_stress": { "$ref": "#/$defs/object" },
    "signature_behaviors": {
      "type": "array",
      "items": { "$ref": "#/$defs/signature_behavior" }
    },
    "narrative_engine": { "$ref": "#/$defs/object" },
    "game_mechanics": { "$ref": "#/$defs/object" },
    "ai_generation": { "$ref": "#/$defs/object" },
    "project_usage": { "$ref": "#/$defs/object" },
    "epistemic_metadata": { "$ref": "#/$defs/object" },
    "context_registry": { "$ref": "#/$defs/object" },
    "export_policy_id": { "type": "string" },
    "target_context_id": { "type": "string" },
    "export_type": { "type": "string" },
    "exported_at": { "type": "string" },
    "excluded_counts": { "$ref": "#/$defs/object" },
    "export_audit_event": { "$ref": "#/$defs/audit_event" },
    "source_notes": { "$ref": "#/$defs/object" },
    "specialized_profiles": { "$ref": "#/$defs/object" },
    "governance": { "$ref": "#/$defs/governance" },
    "profile_evolution": { "$ref": "#/$defs/profile_evolution" },
    "generated_content": { "$ref": "#/$defs/object" },
    "extensions": {
      "type": "object",
      "description": "Unknown imported fields preserved during migration.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "object": {
      "type": "object",
      "additionalProperties": true
    },
    "graph_link": {
      "type": "object",
      "required": ["target_entity_id", "relationship_type"],
      "properties": {
        "target_entity_id": { "type": "string" },
        "relationship_type": { "type": "string" },
        "strength": { "type": ["string", "number"] },
        "notes": { "type": "string" },
        "context_id": { "type": "string" },
        "information_type": { "type": "string" },
        "reality_status": { "$ref": "#/$defs/reality_status" },
        "perspective": { "$ref": "#/$defs/perspective" }
      },
      "additionalProperties": true
    },
    "graph_entity": {
      "type": "object",
      "required": ["entity_id", "entity_type", "display_name", "created_at", "updated_at", "tags", "notes", "relationships"],
      "properties": {
        "entity_id": { "type": "string" },
        "entity_type": {
          "type": "string",
          "enum": ["person", "relationship", "organization", "location", "event", "asset", "story_object", "project", "faction", "concept"]
        },
        "profile_classification": { "type": "string" },
        "entity_subtype": { "type": "string" },
        "display_name": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "relationships": { "type": "array", "items": { "$ref": "#/$defs/graph_link" } }
      },
      "additionalProperties": true
    },
    "relationship_entity": {
      "type": "object",
      "properties": {
        "relationship_id": { "type": "string" },
        "person_a": { "type": "string" },
        "person_b": { "type": "string" },
        "relationship_type": { "type": "string" },
        "trust_level": { "type": "string" },
        "conflict_level": { "type": "string" },
        "history_level": { "type": "string" },
        "influence_level": { "type": "string" },
        "communication_frequency": { "type": "string" },
        "relationship_health": { "type": "string" },
        "running_dynamic": { "type": "string" },
        "inside_jokes": { "type": "string" },
        "shared_history": { "type": "string" },
        "relationship_notes": { "type": "string" },
        "confidence_level": { "type": "string" },
        "canon_level": { "type": "string" },
        "consent_status": { "type": "string" },
        "requested_visibility": { "$ref": "#/$defs/visibility" },
        "person_a_approval": { "type": "string" },
        "person_b_approval": { "type": "string" },
        "reviewer_status": { "type": "string" },
        "context_id": { "type": "string" },
        "information_type": { "type": "string" },
        "reality_status": { "$ref": "#/$defs/reality_status" },
        "perspective": { "$ref": "#/$defs/perspective" }
      },
      "additionalProperties": true
    },
    "organization_entity": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "organization_name": { "type": "string" },
        "founding_date": { "type": "string" },
        "description": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "roles": { "type": "array", "items": { "type": "string" } },
        "projects": { "type": "array", "items": { "type": "string" } },
        "associated_locations": { "type": "array", "items": { "type": "string" } },
        "assets": { "type": "array", "items": { "type": "string" } },
        "history": { "type": "string" },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "faction_entity": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "faction_name": { "type": "string" },
        "description": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "roles": { "type": "array", "items": { "type": "string" } },
        "projects": { "type": "array", "items": { "type": "string" } },
        "associated_locations": { "type": "array", "items": { "type": "string" } },
        "assets": { "type": "array", "items": { "type": "string" } },
        "goals": { "type": "string" },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "location_entity": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "display_name": { "type": "string" },
        "location_type": { "type": "string" },
        "description": { "type": "string" },
        "associated_people": { "type": "array", "items": { "type": "string" } },
        "associated_events": { "type": "array", "items": { "type": "string" } },
        "associated_organizations": { "type": "array", "items": { "type": "string" } },
        "associated_assets": { "type": "array", "items": { "type": "string" } },
        "coordinates_optional": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "event_entity": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "title": { "type": "string" },
        "event_date": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "organizations": { "type": "array", "items": { "type": "string" } },
        "locations": { "type": "array", "items": { "type": "string" } },
        "assets": { "type": "array", "items": { "type": "string" } },
        "stories": { "type": "array", "items": { "type": "string" } },
        "outcomes": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "story_object_entity": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "related_events": { "type": "array", "items": { "type": "string" } },
        "related_locations": { "type": "array", "items": { "type": "string" } },
        "related_people": { "type": "array", "items": { "type": "string" } },
        "related_assets": { "type": "array", "items": { "type": "string" } },
        "importance": { "type": "string" },
        "canonical_status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "project_entity": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "project_name": { "type": "string" },
        "description": { "type": "string" },
        "contributors": { "type": "array", "items": { "type": "string" } },
        "organizations": { "type": "array", "items": { "type": "string" } },
        "assets": { "type": "array", "items": { "type": "string" } },
        "related_people": { "type": "array", "items": { "type": "string" } },
        "related_events": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string" },
        "repository_links": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "concept_entity": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "concept_name": { "type": "string" },
        "definition": { "type": "string" },
        "summary": { "type": "string" },
        "related_people": { "type": "array", "items": { "type": "string" } },
        "related_projects": { "type": "array", "items": { "type": "string" } },
        "related_stories": { "type": "array", "items": { "type": "string" } },
        "related_assets": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "timeline_entry": {
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "entity_id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "notes": { "type": "string" },
        "related_entities": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "relationship": {
      "type": "object",
      "properties": {
        "related_person": { "type": "string" },
        "relationship_id": { "type": "string" },
        "relationship_type": { "type": "string" },
        "trust_level": { "type": "string" },
        "conflict_level": { "type": "string" },
        "history_level": { "type": "string" },
        "influence_level": { "type": "string" },
        "emotional_tone": { "type": "string" },
        "running_dynamic": { "type": "string" },
        "notes": { "type": "string" },
        "story_source": { "type": "string" },
        "confidence_canon": { "type": "string" },
        "visibility": { "$ref": "#/$defs/visibility" },
        "bilateral_approval_required": { "type": "boolean" },
        "approval_status": { "type": "string" },
        "context_id": { "type": "string" },
        "information_type": { "type": "string" },
        "reality_status": { "$ref": "#/$defs/reality_status" },
        "perspective": { "$ref": "#/$defs/perspective" }
      },
      "additionalProperties": true
    },
    "knowledge_domain": {
      "type": "object",
      "properties": {
        "domain": { "type": "string" },
        "expertise_level": { "type": "string" },
        "confidence_level": { "type": "string" },
        "lived_experience": { "type": "string" },
        "public_authority": { "type": "string" },
        "notes": { "type": "string" },
        "dialogue_use": { "type": "string" }
      },
      "additionalProperties": true
    },
    "signature_behavior": {
      "type": "object",
      "properties": {
        "behavior": { "type": "string" },
        "context": { "type": "string" },
        "frequency": { "type": "string" },
        "comedic_exaggeration_potential": { "type": "string" },
        "game_use_notes": { "type": "string" },
        "dialogue_use_notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "asset": {
      "type": "object",
      "properties": {
        "asset_id": { "type": "string" },
        "asset_type": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "linked_entity_id": { "type": "string" },
        "linked_project": { "type": "string" },
        "file_name": { "type": "string" },
        "file_extension": { "type": "string" },
        "file_size": { "type": "string" },
        "url": { "type": "string" },
        "local_path": { "type": "string" },
        "thumbnail_url": { "type": "string" },
        "date_added": { "type": "string" },
        "last_modified": { "type": "string" },
        "source": { "type": "string" },
        "creator": { "type": "string" },
        "copyright_holder": { "type": "string" },
        "license_type": { "type": "string" },
        "consent_status": { "type": "string" },
        "canon_level": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "associated_projects": { "type": "array", "items": { "type": "string" } },
        "use_cases": { "type": "array", "items": { "type": "string" } },
        "do_not_use_for": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "asset_group": {
      "type": "object",
      "properties": {
        "group_id": { "type": "string" },
        "group_name": { "type": "string" },
        "description": { "type": "string" },
        "asset_ids": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "style_guide": {
      "type": "object",
      "properties": {
        "guide_name": { "type": "string" },
        "description": { "type": "string" },
        "asset_ids": { "type": "array", "items": { "type": "string" } },
        "prompt_notes": { "type": "string" },
        "negative_prompt_notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "visibility": {
      "type": "string",
      "enum": ["private", "reviewer_only", "project_only", "exportable"]
    },
    "reality_status": {
      "type": "string",
      "enum": ["factual", "subjective", "community_perception", "speculative", "fictional", "parody", "lore", "unknown"]
    },
    "perspective": {
      "type": "string",
      "enum": ["self_report", "community", "aggregated_observation", "reviewer_observation", "project_author", "third_party", "unknown"]
    },
    "profile_evolution": {
      "type": "object",
      "description": "Additive living-record layer for stable identity, pending changes, applied versions, and audit events. This lets profiles evolve without resubmitting or replacing the whole profile.",
      "required": ["model_version", "stable_identity_paths", "living_record_paths", "pending_changes", "applied_versions", "audit_events"],
      "properties": {
        "model_version": { "type": "string" },
        "stable_identity_paths": { "type": "array", "items": { "type": "string" } },
        "living_record_paths": { "type": "array", "items": { "type": "string" } },
        "pending_changes": { "type": "array", "items": { "$ref": "#/$defs/change_request" } },
        "applied_versions": { "type": "array", "items": { "$ref": "#/$defs/version_history_entry" } },
        "audit_events": { "type": "array", "items": { "$ref": "#/$defs/audit_event" } },
        "applied_change_ids": { "type": "array", "items": { "type": "string" } },
        "rejected_change_ids": { "type": "array", "items": { "type": "string" } },
        "withdrawn_change_ids": { "type": "array", "items": { "type": "string" } },
        "identity_layers": { "$ref": "#/$defs/object" }
      },
      "additionalProperties": true
    },
    "governance": {
      "type": "object",
      "description": "Ownership, editor/reviewer permissions, claims, change review, relationship approval, lifecycle, and export controls.",
      "required": ["profile_owner", "review_owner", "claim_requests", "change_requests", "relationship_approvals", "version_history", "audit_trail"],
      "properties": {
        "profile_owner": { "type": "string" },
        "owner_contact": { "type": "string" },
        "review_owner": { "type": "string" },
        "editors": { "type": "array", "items": { "$ref": "#/$defs/profile_actor" } },
        "reviewers": { "type": "array", "items": { "$ref": "#/$defs/profile_actor" } },
        "permission_rules": { "type": "array", "items": { "$ref": "#/$defs/permission_rule" } },
        "claim_status": {
          "type": "string",
          "enum": ["draft", "submitted", "needs_verification", "reviewer_pending", "approved", "rejected", "withdrawn"]
        },
        "claim_requests": { "type": "array", "items": { "$ref": "#/$defs/claim_request" } },
        "change_requests": { "type": "array", "items": { "$ref": "#/$defs/change_request" } },
        "relationship_approvals": { "type": "array", "items": { "$ref": "#/$defs/relationship_approval" } },
        "version_history": { "type": "array", "items": { "$ref": "#/$defs/version_history_entry" } },
        "audit_trail": { "type": "array", "items": { "$ref": "#/$defs/audit_event" } },
        "approval_history": { "type": "array", "items": { "$ref": "#/$defs/object" } },
        "change_log": { "type": "array", "items": { "$ref": "#/$defs/object" } },
        "retention_policy": { "type": "string" },
        "expiration_date": { "type": "string" },
        "archive_status": { "type": "string" },
        "export_permissions": { "type": "array", "items": { "type": "string" } },
        "allowed_export_targets": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "profile_actor": {
      "type": "object",
      "properties": {
        "editor_id": { "type": "string" },
        "reviewer_id": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["owner", "editor", "reviewer", "project_viewer", "exporter"]
        },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "scope": { "type": "string" },
        "added_by": { "type": "string" },
        "added_at": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "permission_rule": {
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "action": { "type": "string" },
        "scope": { "type": "string" },
        "review_required": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "claim_request": {
      "type": "object",
      "properties": {
        "claim_id": { "type": "string" },
        "claimant": { "type": "string" },
        "verification_method": { "type": "string" },
        "evidence_summary": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["draft", "submitted", "needs_verification", "reviewer_pending", "approved", "rejected", "withdrawn"]
        },
        "submitted_at": { "type": "string" },
        "reviewed_by": { "type": "string" },
        "reviewed_at": { "type": "string" },
        "reviewer_notes": { "type": "string" },
