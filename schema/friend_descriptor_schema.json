{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kstreet.local/schemas/kstreet.person_profile.2.0.0.json",
  "title": "K Street Person Profile",
  "description": "Durable project-agnostic profile schema for real-person-inspired fictional/game characters, AI generation, narrative systems, and mechanics.",
  "type": "object",
  "required": [
    "schema_version",
    "schema_name",
    "metadata",
    "consent",
    "identity",
    "appearance",
    "personality",
    "motivation_values",
    "decision_making",
    "social_relationship_model",
    "knowledge_domains",
    "humor_communication",
    "conflict_stress_response",
    "signature_behaviors",
    "narrative_engine",
    "game_mechanics",
    "ai_generation_metadata",
    "privacy",
    "extensions"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "schema_name": { "const": "kstreet.person_profile" },
    "metadata": {
      "type": "object",
      "required": ["created_at", "updated_at", "source", "record_id"],
      "properties": {
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "source": { "type": "string" },
        "record_id": { "type": "string" },
        "migrated_from": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "consent": {
      "type": "object",
      "properties": {
        "permission_to_store": { "type": "boolean" },
        "permission_to_use_as_fictional_character": { "type": "boolean" },
        "permission_to_use_for_art_prompts": { "type": "boolean" },
        "permission_to_reuse_across_projects": { "type": "boolean" },
        "permission_to_contact_for_clarification": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "identity": { "$ref": "#/$defs/stringMap" },
    "appearance": { "$ref": "#/$defs/stringMap" },
    "personality": { "$ref": "#/$defs/mixedMap" },
    "motivation_values": { "$ref": "#/$defs/mixedMap" },
    "decision_making": { "$ref": "#/$defs/stringMap" },
    "social_relationship_model": { "$ref": "#/$defs/mixedMap" },
    "knowledge_domains": {
      "type": "object",
      "properties": {
        "domains": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "domain_name": { "type": "string" },
              "expertise_level": { "type": "string", "enum": ["", "novice", "beginner", "intermediate", "advanced", "expert"] },
              "confidence": { "type": "string" },
              "notes": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "humor_communication": { "$ref": "#/$defs/mixedMap" },
    "conflict_stress_response": { "$ref": "#/$defs/mixedMap" },
    "signature_behaviors": {
      "type": "object",
      "properties": {
        "behaviors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "behavior": { "type": "string" },
              "context": { "type": "string" },
              "comedic_exaggeration_potential": { "type": "string" },
              "game_use_notes": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "narrative_engine": { "$ref": "#/$defs/mixedMap" },
    "game_mechanics": { "$ref": "#/$defs/mixedMap" },
    "ai_generation_metadata": { "$ref": "#/$defs/mixedMap" },
    "exports": { "$ref": "#/$defs/mixedMap" },
    "privacy": {
      "type": "object",
      "properties": {
        "contains_private_contact_info": { "type": "boolean" },
        "contains_boundaries": { "type": "boolean" },
        "public_repo_safe": { "type": "boolean" },
        "review_status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "description": "Unknown imported fields preserved during migration.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "stringMap": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "array", "object", "null"] }
    },
    "mixedMap": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
